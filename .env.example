# 宿主机目录
FRONTEND_NGINX_HOST_PATH=/srv/safetyraise/nginx
LETSENCRYPT_CONF_HOST_PATH=/srv/safetyraise/letsencrypt/conf
LETSENCRYPT_WWW_HOST_PATH=/srv/safetyraise/letsencrypt/www
# 建议在 212 上把 213 的知识库目录只读挂载到这个路径，例如 sshfs:
# 213:/srv/safetyraise-data/kbase -> 212:/srv/safetyraise/kbase
KBASE_HOST_PATH=/srv/safetyraise/kbase
MODELS_HOST_PATH=/srv/safetyraise/models
HF_HOME_HOST_PATH=/srv/safetyraise/huggingface
# 建议和知识库一样放到 213，再从 212 挂载过来，减少 212 本地磁盘占用。
BACKEND_DATA_HOST_PATH=/srv/safetyraise/runtime

# 域名与 HTTPS
LETSENCRYPT_PRIMARY_DOMAIN=example.com
LETSENCRYPT_DOMAINS=example.com
LETSENCRYPT_EMAIL=
FRONTEND_PORT=80
FRONTEND_HTTPS_PORT=443

# 通用运行参数
TZ=Asia/Shanghai
INSTALL_VIDEO_DEPS=true
VITE_API_BASE=
# Docker 容器日志上限（frontend/backend 默认使用 json-file）
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=5

# 数据库 / 鉴权
# 默认按双机部署填写：应用机 212 连接数据库机 213
DATABASE_DSN=postgresql://<DB_USER>:<DB_PASSWORD>@<DATA_SERVER_IP>:5432/safetyraise
AUTH_JWT_SECRET=change-me-in-production
BOOTSTRAP_ADMIN_USERNAME=safetyraise
BOOTSTRAP_ADMIN_PASSWORD=SafetyRaise@2026
BOOTSTRAP_ADMIN_DISPLAY_NAME=SafetyRAISE 管理员

# 专家模型
# 默认模型仓库：
# https://huggingface.co/suyuan37/SafetyRAISE-TS-Qwen3
# 注意：这里填写的是推理服务实际加载后的模型名，服务本身需要兼容 OpenAI Chat Completions。
EXPERT_LOCAL_MODEL=safetyraise
EXPERT_LOCAL_BASE_URL=https://<MODEL_API_HOST>/v1
EXPERT_LOCAL_API_KEY_ENV=QIANYAN_API_KEY
EXPERT_LOCAL_API_KEY=

# lite 档模型（OpenAI 兼容）
# 对应 workflow*.yaml 里的 report_external.endpoints[lite_compatible]
LITE_MODEL_NAME=wukomg@bf16
LITE_MODEL_ROOT_URL=https://<MODEL_API_HOST>/v1
LITE_MODEL_CHAT_URL=https://<MODEL_API_HOST>/v1/chat/completions
LITE_MODEL_API_KEY_ENV=QIANYAN_API_KEY
LITE_MODEL_API_KEY=
QIANYAN_API_KEY=

# 报告 / 视觉模型
# pro 档默认使用 OPENROUTER_API_KEY
# max 档默认也使用 OPENROUTER_API_KEY
# 视觉模型默认也使用 OPENROUTER_API_KEY
OPENROUTER_API_KEY=

# embedding / reranker
# embedding 需要提供 OpenAI 兼容的 /v1/embeddings 接口。
# 推荐模型来源：Qwen/Qwen3-Embedding-0.6B
RETRIEVAL_EMBEDDING_BASE_URL=https://<MODEL_API_HOST>/v1
RETRIEVAL_EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b
RETRIEVAL_EMBEDDING_API_KEY_ENV=QIANYAN_API_KEY
RETRIEVAL_EMBEDDING_API_KEY=
# reranker 当前默认停用，不再作为 212 新服务器的部署前提。
# 如果未来恢复独立 reranker 服务，再填写下面这些可选项。
RETRIEVAL_RERANKER_BASE_URL=http://retrieval-reranker:80
RETRIEVAL_RERANKER_MODEL=Alibaba-NLP/gte-multilingual-reranker-base
RETRIEVAL_RERANKER_API_KEY_ENV=
RETRIEVAL_RERANKER_API_KEY=

# 可选：知识库与 YOLO 路径覆写
# 如果你直接把 YOLO 权重放在仓库根目录 models/yolo11n.pt，可以不填 YOLO_MODEL_PATH。
KBASE_MANIFEST_PATH=
KBASE_CHUNKS_PATH=
KBASE_RULES_PATH=
KBASE_SEARCH_INDEX_PATH=
KBASE_DENSE_MANIFEST_PATH=
KBASE_DENSE_RECORDS_PATH=
KBASE_DENSE_VECTORS_PATH=
YOLO_MODEL_PATH=
