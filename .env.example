# 宿主机目录
FRONTEND_NGINX_HOST_PATH=/srv/safetyraise/nginx
LETSENCRYPT_CONF_HOST_PATH=/srv/safetyraise/letsencrypt/conf
LETSENCRYPT_WWW_HOST_PATH=/srv/safetyraise/letsencrypt/www
KBASE_HOST_PATH=/srv/safetyraise/kbase
MODELS_HOST_PATH=/srv/safetyraise/models
HF_HOME_HOST_PATH=/srv/safetyraise/huggingface

# 域名与 HTTPS
LETSENCRYPT_PRIMARY_DOMAIN=example.com
LETSENCRYPT_DOMAINS=example.com
LETSENCRYPT_EMAIL=ops@example.com

# 通用运行参数
TZ=Asia/Shanghai
INSTALL_VIDEO_DEPS=true
VITE_API_BASE=

# 专家模型
# 默认模型仓库：
# https://huggingface.co/suyuan37/SafetyRAISE-TS-Qwen3
# 注意：这里填写的是推理服务实际加载后的模型名，服务本身需要兼容 OpenAI Chat Completions。
EXPERT_LOCAL_MODEL=suyuan37/SafetyRAISE-TS-Qwen3
EXPERT_LOCAL_BASE_URL=http://host.docker.internal:1234/v1
EXPERT_LOCAL_API_KEY_ENV=
EXPERT_LOCAL_API_KEY=

# lite 档模型（OpenAI 兼容）
# 对应 workflow*.yaml 里的 report_external.endpoints[lite_compatible]
LITE_MODEL_NAME=qwen2.5-7b-instruct
LITE_MODEL_ROOT_URL=http://host.docker.internal:1234
LITE_MODEL_CHAT_URL=http://host.docker.internal:1234/v1/chat/completions
LITE_MODEL_API_KEY_ENV=
LITE_MODEL_API_KEY=

# 报告 / 视觉模型
# pro 档默认使用 OPENROUTER_API_KEY
# max 档默认使用 DUCKCODING_API_KEY
# 视觉模型默认也使用 OPENROUTER_API_KEY
OPENROUTER_API_KEY=
DUCKCODING_API_KEY=

# embedding / reranker
# embedding 需要提供 OpenAI 兼容的 /v1/embeddings 接口。
# 推荐模型来源：Qwen/Qwen3-Embedding-0.6B
RETRIEVAL_EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
RETRIEVAL_EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b
RETRIEVAL_EMBEDDING_API_KEY_ENV=
RETRIEVAL_EMBEDDING_API_KEY=
# reranker 需要提供 /rerank 接口。仓库默认 Docker sidecar 就是给它准备的。
# 推荐模型来源：Alibaba-NLP/gte-multilingual-reranker-base
RETRIEVAL_RERANKER_BASE_URL=http://retrieval-reranker:80
RETRIEVAL_RERANKER_MODEL=Alibaba-NLP/gte-multilingual-reranker-base
RETRIEVAL_RERANKER_API_KEY_ENV=
RETRIEVAL_RERANKER_API_KEY=

# 可选：知识库与 YOLO 路径覆写
# 如果你直接把 YOLO 权重放在仓库根目录 models/yolo11n.pt，可以不填 YOLO_MODEL_PATH。
KBASE_MANIFEST_PATH=
KBASE_CHUNKS_PATH=
KBASE_RULES_PATH=
KBASE_SEARCH_INDEX_PATH=
KBASE_DENSE_MANIFEST_PATH=
KBASE_DENSE_RECORDS_PATH=
KBASE_DENSE_VECTORS_PATH=
YOLO_MODEL_PATH=
